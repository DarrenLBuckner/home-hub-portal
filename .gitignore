# Dependency directories
node_modules/
.pnp/
.pnp.js/

# Next.js build output
.next/
out/

# Production build
/build

# Env files (CRITICAL FOR SECURITY)
.env
.env*
.env.local
.env.local.secure
.env.development.local
.env.test.local
.env.production.local

# Utility scripts that may contain sensitive data
fix-*.js
debug-*.js

# Logging
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Vercel
.vercel

# TypeScript v1 compiled files
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env.local

# Mac files
.DS_Store

# VS Code settings
.vscode/

# Temporary files
*.swp
*.swo
*~

# Backup files
*.bak

# Supabase specific
supabase/.branches
supabase/.temp

# Debug and development files that may contain secrets
debug-*.js
debug-*.ts
*.sql
!supabase/migrations/*.sql
test-*.js
test-*.ts

# Talon voice commands
*.talon

# Claude Code per-user settings (permissions allowlist) — should not be shared
.claude/settings.local.json

# Claude Code transient state
.claude/scheduled_tasks.lock

# VS Code workspace files (personal/per-machine)
*.code-workspace
